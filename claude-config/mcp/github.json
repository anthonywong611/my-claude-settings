{
  "_doc": "Reference config for the GitHub MCP server. Actual wiring is in settings.json.",
  "server": "@modelcontextprotocol/server-github",
  "install": "npm install -g @modelcontextprotocol/server-github",
  "env_vars": {
    "GITHUB_PERSONAL_ACCESS_TOKEN": "PAT with: repo, pull_requests, read:org"
  },
  "capabilities": [
    "list_repos", "get_file_contents", "create_or_update_file",
    "search_code", "create_issue", "list_pull_requests",
    "create_pull_request", "get_pull_request_diff", "merge_pull_request"
  ]
}
